{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"Logo.png"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit helps you protect your software with commercial licenses on all major Apple platforms (iOS, macOS, tvOS and watchOS)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit lets you define licenses with code that is compiled into the product binary, read licenses from files, validate licenses from remote APIs, integrate with external services like Gumroad, etc."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit licenses can specify and validate expiration date, platform, bundle ID, tier, environment, features, and much, much more."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit lets you cache validation results to handle temporary connectivity loss, and use service proxying to use multiple services to validate license keys."}]},{"anchor":"Pricing","level":2,"type":"heading","text":"Pricing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit requires a commercial license to be used. It’s free to start using and affordable to scale."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can purchase a license from the "},{"type":"reference","isActive":true,"identifier":"https:\/\/getlicensekit.com"},{"type":"text","text":" or use "},{"type":"codeVoice","code":"FREE"},{"type":"text","text":" as license key to use the library with a limited number of code- and file-based licenses and features."}]},{"anchor":"Installation","level":2,"type":"heading","text":"Installation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit can be installed with the Swift Package Manager:"}]},{"type":"codeListing","syntax":null,"code":["https:\/\/github.com\/LicenseKit\/LicenseKit.git"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit only has to be added to the main app target. If you are using LicenseKit with a library, make sure to set up your Swift package so that your users get both your library and LicenseKit when fetching your package."}]},{"anchor":"Getting-started","level":2,"type":"heading","text":"Getting started"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Getting-Started"},{"type":"text","text":" article has a guide to help you get started with LicenseKit."}]},{"anchor":"Repository","level":2,"type":"heading","text":"Repository"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more information, demo apps, issue tracking, etc., visit the "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/LicenseKit\/LicenseKit"},{"type":"text","text":"."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["\/documentation\/licensekit"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/licensekit"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"LicenseKit helps you protect your Swift-based software with commercial licenses."}],"kind":"symbol","metadata":{"roleHeading":"Framework","externalID":"LicenseKit","title":"LicenseKit","symbolKind":"module","role":"collection","modules":[{"name":"LicenseKit"}]},"hierarchy":{"paths":[[]]},"topicSections":[{"title":"Articles","identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Getting-Started","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Licenses","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Services","doc:\/\/com.licensekit.LicenseKit\/doc