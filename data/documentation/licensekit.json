{"topicSections":[{"title":"Articles","identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Licenses","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Services"],"anchor":"Articles"},{"title":"Essentials","identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType"],"anchor":"Essentials"},{"title":"Integrations","identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseIntegrations"],"anchor":"Integrations"},{"title":"Classes","identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseStore"],"generated":true,"anchor":"Classes"},{"title":"Extended Modules","identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Foundation","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Swift"],"generated":true,"anchor":"Extended-Modules"}],"sections":[],"metadata":{"symbolKind":"module","role":"collection","title":"LicenseKit","modules":[{"name":"LicenseKit"}],"roleHeading":"Framework","externalID":"LicenseKit"},"kind":"symbol","variants":[{"paths":["\/documentation\/licensekit"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/licensekit"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit","interfaceLanguage":"swift"},"hierarchy":{"paths":[[]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"LicenseKit helps you protect your Swift-based software with commercial licenses."}],"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"identifier":"Logo.png","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"LicenseKit lets you protect your software with commercial licenses on most Apple platforms (iOS, macOS, tvOS, watchOS, & visionOS).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"LicenseKit lets you define licenses with code, read licenses from files, validate licenses from an API, integrate with external services like Gumroad, etc. It can validate expiration date, platform, bundle ID, tier, environment, features, and much more.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit lets you cache licenses to handle temporary connectivity loss, and use service proxying to combine multiple data sources."}]},{"type":"heading","anchor":"Installation","text":"Installation","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit can be installed with the Swift Package Manager:"}]},{"type":"codeListing","code":["https:\/\/github.com\/Kankoda\/LicenseKit.git"],"syntax":null},{"type":"heading","anchor":"Getting-Started","text":"Getting Started","level":2},{"type":"paragraph","inlineContent":[{"text":"In LicenseKit, a ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","isActive":true},{"text":" is used to manage product licenses. Use ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"your","type":"text"}]},{"text":" LicenseKit license key to create a ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","isActive":true},{"text":" with the ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType","isActive":true},{"text":" that you want to use to access your product licenses.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For instance, this would create a license engine that only has two hard-coded licenses that will be resolved and validated on-device:"}]},{"type":"codeListing","code":["let engine = try await LicenseEngine(licenseKey: \"your-license-key\") {","    .binary(","        licenses: [","            License(licenseKey: \"license-key-1\"),","            License(licenseKey: \"license-key-2\")","        ]","    )","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Once you have a license engine, you can use it to resolve and validate licenses for your product, by letting users enter ","type":"text"},{"inlineContent":[{"text":"their","type":"text"}],"type":"emphasis"},{"text":" license key:","type":"text"}]},{"type":"codeListing","code":["do {","    let license = try await engine.getLicense(for: \"license-key-1\")","    \/\/ Set up your app\/SDK with the license.","    \/\/ Perform further license validations, if needed.","    \/\/ Store the license for the current session, etc.","} catch {","    \/\/ Handle the error and inform your users","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The engine will retrieve a license with the service type you defined, then validate any matching license for the current platform, product bundle & date. You can perform more validations after retrieving the license, using the many license validation functions.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Licenses","isActive":true,"type":"reference"},{"text":" for more information about the ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true,"type":"reference"},{"text":" model and ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Services","isActive":true,"type":"reference"},{"text":" for more information about the available service types.","type":"text"}]},{"type":"heading","anchor":"Apps-vs-libraries","text":"Apps vs. libraries","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You will most probably have to set up your engine and handle licenses a bit differently in apps and libraries."}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An app can create a "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","isActive":true},{"type":"text","text":" on launch, or whenever you need one. You can then provide a UI where users can enter their license key to unlock features in the app."}]}]},{"content":[{"inlineContent":[{"text":"A library should provide a way for developers to set up license-protected features by entering ","type":"text"},{"inlineContent":[{"text":"their","type":"text"}],"type":"emphasis"},{"text":" license key. You can then use it to set up a license engine, fetch and validate the developer license, then use the returned license (if any) to unlock features in the SDK.","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Pricing","text":"Pricing","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit requires a commercial license to be used. It’s free to start using and affordable to scale."}]},{"type":"paragraph","inlineContent":[{"text":"You can purchase a license from the ","type":"text"},{"identifier":"https:\/\/kankoda.com\/licensekit","type":"reference","isActive":true},{"text":" or use ","type":"text"},{"code":"FREE","type":"codeVoice"},{"text":" as license key to use it with a limited set of features and licenses.","type":"text"}]},{"type":"heading","anchor":"Repository","text":"Repository","level":2},{"type":"paragraph","inlineContent":[{"text":"For more information, demo apps, issue tracking, etc., visit the ","type":"text"},{"identifier":"https:\/\/github.com\/Kankoda\/LicenseKit","isActive":true,"ty