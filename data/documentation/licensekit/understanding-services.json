{"sections":[],"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/licensekit\/understanding-services"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/licensekit\/understanding-services"]}],"metadata":{"role":"article","modules":[{"name":"LicenseKit"}],"title":"Understanding License Services","roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit"]]},"abstract":[{"type":"text","text":"This article describes the LicenseKit license service model and how to define and validate licenses."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Services"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit has many different license service types, that are defined by the "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType","isActive":true},{"type":"text","text":" enum that defines the following:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType\/api(configuration:cached:urlSession:licenseMapping:)","type":"reference","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType\/binary(licenses:)","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType\/fileName(fileName:fileExtension:bundle:componentSeparator:licenseMapping:)","type":"reference","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType\/fileUrl(fileUrl:componentSeparator:licenseMapping:)","type":"reference","isActive":true}]}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType\/gumroad(productId:cached:urlSession:licenseMapping:)"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are two special service types, which are used to create a cached version of any license service, or to create a composite proxy:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType\/cached(service:)","type":"reference","isActive":true}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType\/proxy(services:)","type":"reference","isActive":true}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can specify which service type(s) that you want to use when you create your "},{"isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","type":"reference"},{"type":"text","text":" instance."}]},{"type":"heading","text":"API Licenses","level":2,"anchor":"API-Licenses"},{"type":"paragraph","inlineContent":[{"text":"You can use an API service to fetch licenses from a remote Rest API. Connecting over the Internet means that the user must be online.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To map licenses from a specific API, you must define a custom "},{"type":"codeVoice","code":"Decodable"},{"type":"text","text":" type that can decode a specific API response, for instance:"}]},{"syntax":"swift","type":"codeListing","code":["struct MyApiLicenseModel: Decodable {","","    let licenseKey: String","    let customerName: String","    let tier: String","","    var license: License {","        License(","            licenseKey: licenseKey,","            customer: .init(name: customerName)","            tier: .init(name: tier)","        )","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"This type would be able to map the following response right away, and can define custom ","type":"text"},{"code":"CodingKeys","type":"codeVoice"},{"text":" to support custom mappings:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["{","    \"licenseKey\": \"ABC123\",","    \"customerName\": \"Cool Company Ltd.\",","    \"expirationDate\": \"2027-01-31\"","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can now setup an API service with an API-specific config and a mapping function that decodes data and maps it to a "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","    try .api(","        configuration: .init(","            url: { licenseKey in URL(string: \"https:\/\/myapi.com\/licenses\/\\(licenseKey)\")! },","            httpMethod: { licenseKey in \"POST\" },","            httpHeaders: { licenseKey in [\"api-token\": \"ejiwaogja=\"] }","        ),","        licenseMapping { data in","            let decoder = JSONDecoder()","            let apiLicense = try decoder.decode(MyApiLicenseModel.self, from: data)","            return apiLicense.license","        }","    )","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This way to provide an API-specific configuration and mapping function lets you customize this general API service to great extent."}]},{"type":"heading","text":"Binary Licenses","level":2,"anchor":"Binary-Licenses"},{"type":"paragraph","inlineContent":[{"text":"Binary licenses are defined with source code that is hard-coded into your binary, and will be validated on-device. You can define binary licenses by creating static ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","type":"reference"},{"text":" values, for instance:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["extension License {","","    \/\/\/ A basic license that only defines a license key","    static let basicLicense = License(","        licenseKey: \"DCE54718-A214-40E7-B3E8-3C7B1967F485\")","","    \/\/\/ A license that defines customer, tier, features, etc:","    static let extensiveLicense = License(","        licenseKey: \"ABCDEFGH-IJKL-MNOP-QRST-UVWXYZ123456\"","        customer: .myCustomer,","        tier: .gold,","        expirationDate: Date(year: 2025, month: 01, day: 01),","        allowsExpiration: false,","        platforms: [.iOS, .tvOS],","        bundleIds: [\"com.customer.library\"]","    )","}"]},{"type":"paragraph","inlineContent":[{"text":"You can create license collections to define convenient access to your binary licenses, then setup a license engine with these licenses:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["extension Collection where Element == License {","","    static var myProductLicenses: [License.Customer] {","        [.basicLicense, .extensiveLicense]","    }","}","","let engine = try await LicenseEngine(licenseKey: \"...\") {","   try .binary(licenses: .myProductLicenses)","}"]},{"type":"paragraph","inlineContent":[{"text":"Binary licenses are powerful, but require that you to release a new version of your software to add or remove licenses for your product.","type":"text"}]},{"type":"heading","text":"Cached Licenses","level":2,"anchor":"Cached-Licenses"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use a cached license service to cache any license validation from any other license service. This makes it possible for a user to keep using your software even if the device is temporarily disconnected."}]},{"syntax":"swift","type":"codeListing","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","    try .cached(","        service: .gumroad(...)","    )","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any license validations that fail due to a "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/ValidationError","isActive":true},{"type":"text","text":" causes the cache to reset and the validation to fail with the original error."}]},{"type":"heading","text":"Encrypted License Files (Coming Soon)","level":2,"anchor":"Encrypted-License-Files-Coming-Soon"},{"type":"paragraph","inlineContent":[{"text":"This feature is coming in a future update, and will let you offer a way for customers to register their license by just adding a license file to their bundle. The file is created by encrypting a binary license with CryptoKit, and can be decrypted with an upcoming service type.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Please reach out if you need this feature, as it will help us prioritize it. Everything exists under the hood, but it needs public components.","type":"text"}]},{"type":"heading","text":"File-based Licenses","level":2,"anchor":"File-based-Licenses"},{"type":"paragraph","inlineContent":[{"type":"text","text":"File-based licenses are defined in files that are bundled with your product, for instance a “licenses.csv” file with a row for each license:"}]},{"syntax":null,"type":"codeListing","code":["DCE54718-A214-40E7-B3E8-3C7B1967F485,Microsoft,BASIC,2023-10-01","ABCDEFGH-IJKL-MNOP-QRST-UVWXYZ123456,Apple,GOLD,2023-01-01","..."]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can then setup your license engine with a file-based service that uses your local license file:"}]},{"syntax":"swift","type":"codeListing","code":["let engine = try await LicenseEngine(licenseKey: \"...\") {","    try .file(","        fileName: \"licenses\",","        fileExtension: \"csv\",","        componentSeparator: \",\"","    ) { rows in","        rows.map {","            License(","                licenseKey: row[0],","                customer: .init(name: row[1])","                tier: .init(name: row[2])","            )","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The code above parses a “licenses.csv” file in the main bundle, then maps every row to a license by using the first value as license key, the second as customer (company) name, and the third as license "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct"},{"type":"text","text":" (“basic”, “silver”, “enterprise”, etc.)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"License files are convenient, but require that you to release a new version of your software to add or remove licenses for your product."}]},{"type":"heading","text":"Gumroad Licenses","level":2,"anchor":"Gumroad-Licenses"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use a Gumroad service to fetch licenses from the Gumroad license API. The service can automatically map Gumroad purchase data to a license, and lets you pass in a license mapping function that maps the raw Gumroad response to a "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","type":"reference","isActive":true},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","    try .gumroad(","        productId: \"unique-product-id\",","        licenseMapping: { response in","            var license = response.license","            \/\/ You can customize or replace this standard license here","            return license","        }","    )","}"]},{"type":"paragraph","inlineContent":[{"text":"You can either just return the response’s original license, customize or replace the license, or handle the response in any way you want.","type":"text"}]},{"type":"heading","text":"Service Proxying","level":2,"anchor":"Service-Proxying"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use a service proxy to combine several services into a single one. This makes is possible to e.g. perform both code-, file- and api-based license validation with a single service, in the sequential order of the provided services."}]},{"syntax":"swift","type":"codeListing","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","    try .proxy(","        services: [","            .binary(","                license: license,","                customerLicenses: .all","            ),","            try .gumroad(","                license: license,","                productId: \"unique-product-id\",","                licenseMapping { response in","                    ...","                }","            )","        ]","    )","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Service proxies are needed to fetch licenses from multiple sources, for instance if you sell subscriptions on multiple platforms. You can apply a different "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Source-swift.enum"},{"type":"text","text":" to each service to determine from where a license originates."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"seeAlsoSections":[{"anchor":"Articles","identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Getting-Started-Article","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Licenses"],"title":"Articles","generated":true}],"references":{"doc://com.licensekit.LicenseKit/documentation/LicenseKit/LicenseServiceType/binary(lice