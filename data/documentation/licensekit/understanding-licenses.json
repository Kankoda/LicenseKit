,"inlineContent":[{"text":"LicenseKit can use various ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType","type":"reference"},{"type":"text","text":"s to fetch licenses in various ways. Read more in "},{"isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Services","type":"reference"},{"text":".","type":"text"}]},{"anchor":"License-Engine","type":"heading","level":2,"text":"License Engine"},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit uses a "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","isActive":true},{"type":"text","text":" to resolve licenses. You can read more about how to create & setup an engine in the main article."}]},{"inlineContent":[{"text":"A ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","isActive":true},{"text":" uses one or multiple ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType","isActive":true},{"type":"text","text":"s to fetch licenses, then perform an initial license validation to verify that the license is valid for the current software and platform, before it returns it to you for further handling."}],"type":"paragraph"},{"text":"License Capabilities","level":2,"anchor":"License-Capabilities","type":"heading"},{"inlineContent":[{"type":"text","text":"A "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","type":"reference","isActive":true},{"type":"text","text":" defines a lot of information, such as expiration date, a license "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct","type":"reference","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Customer-swift.struct","isActive":true},{"type":"text","text":" information, as well as supported bundle IDs, "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform","isActive":true},{"text":"(s), ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment"},{"type":"text","text":"(s), "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature","isActive":true,"type":"reference"},{"text":"(s), etc.","type":"text"}],"type":"paragraph"},{"text":"Tier","type":"heading","level":3,"anchor":"Tier"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A license tier defines the level of service that a specific "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true},{"text":" has access to. Common tiers are ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/basic"},{"type":"text","text":". You can use pre-defined "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/TierGroup","isActive":true},{"text":" groups to get common tier groups, and also define your own tiers:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["extension License.Tier {","","    static let everything = Self(","        id: \"com.mylibrary.license.everything\",","        name: \"The Everything Tier\",","        level: 1_000","    )","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can make certain types or features require a certain license tier. For instance, this class requires at least a "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/silver","isActive":true},{"type":"text","text":" tier:"}]},{"type":"codeListing","syntax":"swift","code":["class CoolFeature {","","    init(license: License) throws {","        try license.validateTier(.silver)","    }","","    ...","}"]},{"inlineContent":[{"type":"text","text":"If you try to create an instance of this class with a license that doesn’t have a proper tier, the validation throws a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/ValidationError"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"heading","level":3,"text":"Platform","anchor":"Platform"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform","isActive":true},{"text":" enum defines different hardware platforms that a ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true,"type":"reference"},{"type":"text","text":" can be valid for, like "},{"isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform\/iOS","type":"reference"},{"type":"text","text":" and "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform\/macOS","isActive":true,"type":"reference"},{"type":"text","text":". This lets you apply different prices for the number of platforms that a license supports."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit automatically validates licenses for the current platform. If a license doesn’t specify a platform, all platforms are supported."}]},{"type":"heading","text":"Environment","anchor":"Environment","level":3},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment"},{"text":" enum defines different environments that a ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true,"type":"reference"},{"type":"text","text":" can be valid for, like "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment\/test","isActive":true},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment\/production"},{"type":"text","text":". This lets you apply different prices for the number of environments that a license supports."}]},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit doesn’t perform environment validation. You can use ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validateEnvironment(_:)","isActive":true},{"text":" to perform this step manually.  If a license doesn’t specify an environment, all environments are supported.","type":"text"}]},{"text":"Features","level":2,"anchor":"Features","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature"},{"text":" protocol can be implemented by types that can be unlocked by a license. This lets you apply different prices for the number of features that a license supports.","type":"text"}]},{"inlineContent":[{"text":"To define a feature, just implement the ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature","isActive":true,"type":"reference"},{"text":" protocol and return an optional ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature\/featureId","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature\/unlockedByTier","isActive":true},{"type":"text","text":". You can let an entire type implement the protocol, or let certain enum cases require a license:"}],"type":"paragraph"},{"code":["enum AppFeature: String, LicenseFeature {","    case .dictation, .localization","    ","    var featureId: String? { ","        switch self {","        case .dictation: rawValue   \/\/ Dictation is a license feature","        case .localization: nil     \/\/ Localization is not a license feature","        }","    }","","    var unlockedByTier: Tier? { .gold }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"We can now add this feature to any license that should have access to it:"}]},{"code":["var license1 = License(","    licenseKey: \"1\"",")","","var license2 = License(","    licenseKey: \"2\", ","    features: [AppFeature.dictation]",")","","var license3 = License(","    licenseKey: \"3\",","    tier: .gold",")"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"We can then validate if a license has access to a certain feature:"}]},{"code":["\/\/ Dictation is a license feature, and requires either the feature or the tier","license1.validateFeature(AppFeature.dictation)    \/\/ False","license2.validateFeature(AppFeature.dictation)    \/\/ True","license3.validateFeature(AppFeature.dictation)    \/\/ True","","\/\/ Localization is not a license feature, since it has no ID","license1.validateFeature(AppFeature.localization) \/\/ True","license2.validateFeature(AppFeature.localization) \/\/ True","license3.validateFeature(AppFeature.localization) \/\/ True"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can even make it impossible to create instances of a type that req