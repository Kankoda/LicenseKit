{"identifier":{"url":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Licenses","interfaceLanguage":"swift"},"sections":[],"metadata":{"roleHeading":"Article","title":"Understanding Licenses","role":"article","modules":[{"name":"LicenseKit"}]},"seeAlsoSections":[{"anchor":"Articles","identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Getting-Started-Article","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Services"],"generated":true,"title":"Articles"}],"hierarchy":{"paths":[["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit"]]},"kind":"article","abstract":[{"type":"text","text":"This article describes the LicenseKit license model."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/licensekit\/understanding-licenses"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/licensekit\/understanding-licenses"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"text":"LicenseKit has a ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true,"type":"reference"},{"text":" model that represents a software license. A licenses can specify activation and expiration dates, the license ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Customer-swift.struct","isActive":true,"type":"reference"},{"text":" as well as which bundle IDs, ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform","isActive":true,"type":"reference"},{"text":"(s), ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment","isActive":true,"type":"reference"},{"text":"(s), ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature","isActive":true},{"type":"text","text":"(s), that can use the license."}],"type":"paragraph"},{"anchor":"How-to-define-customer-licenses","type":"heading","level":2,"text":"How to define customer licenses"},{"inlineContent":[{"text":"LicenseKit can fetch licenses in different ways, by using a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine"},{"text":" with various ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType"},{"text":"s. See the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Getting-Started-Article"},{"text":" article for instructions and the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Services"},{"text":" article for more information about the available license services.","type":"text"}],"type":"paragraph"},{"anchor":"License-Capabilities","type":"heading","level":2,"text":"License Capabilities"},{"inlineContent":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true,"type":"reference"},{"text":" can define a lot of license-specific information, such as expiration date, a license ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Customer-swift.struct","isActive":true,"type":"reference"},{"text":" information, as well as supported bundle IDs, ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform","isActive":true,"type":"reference"},{"text":"(s), ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment","isActive":true,"type":"reference"},{"text":"(s), ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature","isActive":true,"type":"reference"},{"text":"(s), etc.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In the examples below, a ","type":"text"},{"code":".current","type":"codeVoice"},{"text":" license is set up as described in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Getting-Started-Article"},{"text":" article. While you ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"can"}]},{"text":" return a license to your customers and let protected features take a license as init parameter, it’s more convenient for your users if you handle it internally.","type":"text"}],"type":"paragraph"},{"anchor":"Tiers","type":"heading","level":3,"text":"Tiers"},{"inlineContent":[{"type":"text","text":"A license tier defines the level of service that a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License"},{"type":"text","text":" has access to. You can use any of the pre-defined "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/TierGroup"},{"type":"text","text":" values to use some common tier names like "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/small"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/medium"},{"type":"text","text":" & "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/large"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/basic"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/silver"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/gold"},{"type":"text","text":", etc. You can also your own tiers:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["extension License.Tier {","","    static let everything = Self(","        id: \"com.mylibrary.license.everything\",","        name: \"The Everything Tier\",","        level: 1_000","    )","}"]},{"inlineContent":[{"type":"text","text":"You can make certain types or features require a certain license tier. For instance, this feature class requires at least a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/silver"},{"type":"text","text":" license:"}],"type":"paragraph"},{"type":"codeListing","code":["class CoolFeature {","","    init() throws {","        try License.validate(.current) { license in","            try license.validateTier(.silver)","        }","    }","","    ...","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you try to create an instance by providing a license that has a too low tier, the initializer will fail by throwing a "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/ValidationError","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature"},{"type":"text","text":"s to validate certain features, instead of validating a tier directly. A feature can define a minimum tier, which lets you validate if a license either has a feature or meets its required tier."}],"type":"paragraph"},{"anchor":"Bundle","text":"Bundle","type":"heading","level":3},{"inlineContent":[{"text":"A license can be valid for one or multiple bundle IDs. This lets you apply different prices for the number of products that a license can be used in. You can use a .* wildcard suffix in your customer licenses bundle IDs to support all bundles with a certain bundle ID  prefix.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can use the static "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validate(_:bundleId:date:platform:additionalValidation:)","isActive":true},{"type":"text","text":" function or instance function "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validateBundle(_:)","isActive":true},{"type":"text","text":" to validate the license for a certain bundle."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit automatically validates licenses for the current bundle. If a license doesn’t specify a bundle, all bundles are supported."}],"type":"paragraph"},{"anchor":"Dates","text":"Dates","type":"heading","level":3},{"inlineContent":[{"text":"A license can define various dates, like ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/activationDate","type":"reference","isActive":true},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/renewalDate","type":"reference","isActive":true},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/expirationDate","type":"reference","isActive":true},{"text":", etc. While most dates exist to let you and your customers keep track of the license lifecycle, the ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/expirationDate","type":"reference","isActive":true},{"text":" will automatically expire a license.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can use the static "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validate(_:bundleId:date:platform:additionalValidation:)"},{"type":"text","text":" function or instance function "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validateExpirationDate(_:)"},{"type":"text","text":" to validate the license for a certain date. You can set "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/allowsExpiration"},{"type":"text","text":" to allow licenses to expire, for instance if you want to offer more flexibility to trusted customers."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit automatically validates licenses for the current date. If a license doesn’t specify an expiration date, it will never expire."}],"type":"paragraph"},{"anchor":"Environment","text":"Environment","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment","isActive":true},{"type":"text","text":" enum defines different environments that a "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true},{"type":"text","text":" can be valid for, like "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment\/test","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment\/production","isActive":true},{"type":"text","text":". This lets you apply different prices for the number of environments that a license supports."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit doesn’t perform environment validation. You can use "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validateEnvironment(_:)","isActive":true},{"type":"text","text":" to perform this step manually.  If a license doesn’t specify an environment, all environments are supported."}],"type":"paragraph"},{"anchor":"Platform","text":"Platform","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License"},{"type":"text","text":"."},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform"},{"type":"text","text":" enum defines different hardware platforms that a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License"},{"type":"text","text":" can be valid for, like "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform\/iOS"},{"type":"text","text":" and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform\/macOS"},{"type":"text","text":". This lets you apply different prices for the number of platforms that a license supports."}],"type":"paragraph"},{"inlineContent":[{"text":"You can use the static ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validate(_:bundleId:date:platform:additionalValidation:)","isActive":true,"type":"reference"},{"text":" function or instance function ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validatePlatform(_:)","isActive":true,"type":"reference"},{"text":" to validate the license for a certain platform.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit automatically validates licenses for the current platform. If a license doesn’t specify a platform, all platforms are supported."}],"type":"paragraph"},{"anchor":"Features","text":"Features","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature"},{"type":"text","text":" protocol can be implemented by types that can be unlocked by a license. This lets you apply different prices for the features that a license includes."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To define a feature, just implement the "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature","isActive":true},{"type":"text","text":" protocol and return an optional "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature\/featureId","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature\/unlockedByTier","isActive":true},{"type":"text","text":". You can let an entire type implement the protocol, or let certain enum cases require a license to include a certain feature:"}],"type":"paragraph"},{"type":"codeListing","code":["enum AppFeature: String, LicenseFeature {","    case .dictation, .localization","    ","    var featureId: String? { ","        switch self {","        case .dictation: rawValue   \/\/ This returns an ID and is thus a feature","        case .localization: nil     \/\/ This returns nil and is thus NOT a feature","        }","    }","","    var unlockedByTier: Tier? { .gold }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"We can now add this feature to any license that should have access to it:"}],"type":"paragraph"},{"type":"codeListing","code":["var license1 = License(licenseKey: \"1\")","var license2 = License(licenseKey: \"2\",  features: [AppFeature.dictation])","var license3 = License(licenseKey: \"3\", tier: .gold)"],"syntax":"swift"},{"inlineContent":[{"text":"We can then validate if a license has access to a certain feature:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Dictation is a license feature, and requires either the feature or the tier","license1.validateFeature(AppFeature.dictation)    \/\/ False","license2.validateFeature(AppFeature.dictation)    \/\/ True, because it has the feature","license3.validateFeature(AppFeature.dictation)    \/\/ True, because it has a valid tier","","\/\/ Localization is not a license feature, since it has no ID","license1.validateFeature(AppFeature.localization) \/\/ True, because this is not a feature","license2.validateFeature(AppFeature.localization) \/\/ True, because this is not a feature","license3.validateFeature(AppFeature.localization) \/\/ True, because this is not a feature"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"You can use feature validation everywhere, for instance to call certain functions and to even make it impossible to create an instance of a type that requires a certain feature, if the license lacks that feature:"}],"type":"paragraph"},{"type":"codeListing","code":["class DictationService {","","    init() throws {","        try License.validate(.current) { license in","            try license.validateFeature(AppFeatures.dictation)","        }","    }","}"],"syntax":"swift"},{"inlineContent":[{"text":"If you try to create an instance with a license that doesn’t include the dictation feature, the initializer will throw a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/ValidationError"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://com.licensekit.LicenseKit/documentation/LicenseKit":{"kind":"symbol","title":"LicenseKit","role":"collection","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit","url":"\/documentation\/licensekit","type":"topic","abstract":[{"type":"text","text":"LicenseKit helps you protect your Swift-based software with commercial licenses."}]},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/Understanding-Services":{"url":"\/documentation\/licensekit\/understanding-services","title":"Understanding License Services","role":"article","kind":"article","type":"topic","abstract":[{"text":"This article describes the LicenseKit license service model and how to define and validate licenses.","type":"text"}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Services"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/License/Tier-swift.struct/large":{"url":"\/documentation\/licensekit\/license\/tier-swift.struct\/large","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/large","abstract":[{"type":"text","text":"A large tier with level of "},{"type":"codeVoice","code":"2"},{"type":"text","text":"."}],"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"ki