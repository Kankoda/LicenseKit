r(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"validateTier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"Tier","preciseIdentifier":"s:10LicenseKit0A0V4TierV"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"}],"abstract":[{"type":"text","text":"Validate the license meets a certain tier."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validateTier(_:)","kind":"symbol","type":"topic","url":"\/documentation\/licensekit\/license\/validatetier(_:)"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/License":{"role":"symbol","title":"License","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"License"}],"abstract":[{"type":"text","text":"This struct represents a software license and also works as"},{"type":"text","text":" "},{"type":"text","text":"a namespace for license-related types."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"License"}],"url":"\/documentation\/licensekit\/license"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/Understanding-License-Errors":{"role":"article","title":"Understanding License Errors","abstract":[{"type":"text","text":"This article describes the license error model and how to handle errors that are thrown."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Errors","kind":"article","type":"topic","url":"\/documentation\/licensekit\/understanding-license-errors"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/LicenseFeature":{"role":"symbol","title":"LicenseFeature","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"LicenseFeature"}],"abstract":[{"type":"text","text":"This protocol can be implemented by any type that should be"},{"type":"text","text":" "},{"type":"text","text":"used as a license-based feature."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"LicenseFeature"}],"url":"\/documentation\/licensekit\/licensefeature"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/License/Platform":{"role":"symbol","title":"License.Platform","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Platform"}],"abstract":[{"type":"text","text":"This enum specifies the various hardware platforms that"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License"},{"type":"text","text":" can be valid for."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Platform"}],"url":"\/documentation\/licensekit\/license\/platform"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/LicenseError":{"role":"symbol","title":"LicenseError","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"LicenseError"}],"abstract":[{"type":"text","text":"This enum defines various license errors that can be thrown"},{"type":"text","text":" "},{"type":"text","text":"when registering a license key or trying to access features"},{"type":"text","text":" "},{"type":"text","text":"that require a specific license type."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseError","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"LicenseError"}],"url":"\/documentation\/licensekit\/licenseerror"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/License/TierGroup":{"role":"symbol","title":"License.TierGroup","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"TierGroup"}],"abstract":[{"type":"text","text":"A tier group defines tiers that go well together."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/TierGroup","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"TierGroup"}],"url":"\/documentation\/licensekit\/license\/tiergroup"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/Getting-Started":{"role":"article","title":"Getting started","abstract":[{"type":"text","text":"This article describes how to get started with LicenseKit."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Getting-Started","kind":"article","type":"topic","url":"\/documentation\/licensekit\/getting-started"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/LicenseEngine":{"role":"symbol","title":"LicenseEngine","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"LicenseEngine"}],"abstract":[{"type":"text","text":"This is the most central class in LicenseKit and is used to"},{"type":"text","text":" "},{"type":"text","text":"resolve license keys."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"LicenseEngine"}],"url":"\/documentation\/licensekit\/licenseengine"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/License/validate()":{"role":"symbol","title":"validate()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"validate"},{"kind":"text","text":"() "},{"kind":"keyword","text":"throws"}],"abstract":[{"type":"text","text":"Validate the license for the bundle, date & platform."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validate()","kind":"symbol","type":"topic","url":"\/documentation\/licensekit\/license\/validate()"}},"variantOverrides":[{"patch":[{"op":"replace","path":"\/identifier\/interfaceLanguage","value":"occ"},{"op":"add","path":"\/topicSections","value":null},{"op":"replace","path":"\/seeAlsoSections","value":[{"title":"Articles","identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Getting-Started","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Services","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Errors"],"generated":true}]}],"traits":[{"interfaceLanguage":"occ"}]}]}