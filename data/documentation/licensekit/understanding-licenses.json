{"sections":[],"abstract":[{"text":"This article describes the LicenseKit license model.","type":"text"}],"variants":[{"paths":["\/documentation\/licensekit\/understanding-licenses"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/licensekit\/understanding-licenses"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"LicenseKit has a ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true,"type":"reference"},{"text":" model that represents a software license. Licenses can specify expiration date, a license ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Customer-swift.struct","isActive":true,"type":"reference"},{"text":" information, as well as supported bundle IDs, ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform","isActive":true,"type":"reference"},{"text":"(s), ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment","isActive":true,"type":"reference"},{"text":"(s), ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature","isActive":true,"type":"reference"},{"text":"(s), etc.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"LicenseKit can use various ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType","isActive":true,"type":"reference"},{"text":"s to fetch licenses in various ways. Read more in ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Services","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"License-Engine","text":"License Engine","type":"heading"},{"inlineContent":[{"text":"LicenseKit uses a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","type":"reference"},{"text":" to resolve licenses. You can read more about how to create & set up an engine in the main article.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","type":"reference","isActive":true},{"text":" can use one or multiple ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType","type":"reference","isActive":true},{"text":"s to fetch licenses, after which it will perform an initial validation check to verify that the license is valid for the current software and platform, before it returns it to you for further handling.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can pass in a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseStore"},{"text":" into your engine instance, to let it automatically update the store with the last fetched license. You can use the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseStore\/shared"},{"text":" license store, which lets you use ``","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"License-Capabilities","text":"License Capabilities","type":"heading"},{"inlineContent":[{"type":"text","text":"A "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License"},{"type":"text","text":" defines a lot of information, such as expiration date, a license "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct"},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Customer-swift.struct"},{"type":"text","text":" information, as well as supported bundle IDs, "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform"},{"type":"text","text":"(s), "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment"},{"type":"text","text":"(s), "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature"},{"type":"text","text":"(s), etc."}],"type":"paragraph"},{"level":3,"anchor":"Tiers","text":"Tiers","type":"heading"},{"inlineContent":[{"type":"text","text":"A license tier defines the level of service that a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License"},{"type":"text","text":" has access to. You can use any of the pre-defined "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/TierGroup"},{"type":"text","text":"s to use some common tiers like “small, medium, large”, “basic, silver, gold”, etc., or define your own custom tiers:"}],"type":"paragraph"},{"code":["extension License.Tier {","","    static let everything = Self(","        id: \"com.mylibrary.license.everything\",","        name: \"The Everything Tier\",","        level: 1_000","    )","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"You can make certain types or features require a certain license tier. For instance, this feature class requires at least a ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/silver","isActive":true,"type":"reference"},{"text":" license:","type":"text"}],"type":"paragraph"},{"code":["class CoolFeature {","","    init(license: License) throws {","        try license.validateTier(.silver)","    }","","    ...","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"If you try to create an instance by providing a license that has a too low tier, the initializer will fail by throwing a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/ValidationError"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can use ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature","isActive":true,"type":"reference"},{"text":"s to validate certain features, instead of validating a tier directly. A feature can define a minimum tier, which lets you validate if a license either has a feature or meets its required tier.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Platform","text":"Platform","type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform","isActive":true,"type":"reference"},{"text":" enum defines different hardware platforms that a ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true,"type":"reference"},{"text":" can be valid for, like ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform\/iOS","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform\/macOS","isActive":true,"type":"reference"},{"text":". This lets you apply different prices for the number of platforms that a license supports.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can use the static "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validate(_:bundleId:date:platform:additionalValidation:)"},{"type":"text","text":" function or instance function "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validatePlatform(_:)"},{"type":"text","text":" to validate the license for a certain platform."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit automatically validates licenses for the current platform. If a license doesn’t specify a platform, all platforms are supported."}],"type":"paragraph"},{"level":3,"anchor":"Environment","text":"Environment","type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment","isActive":true,"type":"reference"},{"text":" enum defines different environments that a ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true,"type":"reference"},{"text":" can be valid for, like ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment\/test","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment\/production","isActive":true,"type":"reference"},{"text":". This lets you apply different prices for the number of environments that a license supports.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"KeyboardKit doesn’t perform environment validation. You can use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validateEnvironment(_:)"},{"text":" to perform this step manually.  If a license doesn’t specify an environment, all environments are supported.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Features","text":"Features","type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature","type":"reference","isActive":true},{"type":"text","text":" protocol can be implemented by types that can be unlocked by a license. This lets you apply different prices for the features that a license includes."}],"type":"paragraph"},{"inlineContent":[{"text":"To define a feature, just implement the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature"},{"text":" protocol and return an optional ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature\/featureId"},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature\/unlockedByTier"},{"text":". You can let an entire type implement the protocol, or let certain enum cases require a license:","type":"text"}],"type":"paragraph"},{"code":["enum AppFeature: String, LicenseFeature {","    case .dictation, .localization","    ","    var featureId: String? { ","        switch self {","        case .dictation: rawValue   \/\/ Dictation is a license feature","        case .localization: nil     \/\/ Localization is not a license feature","        }","    }","","    var unlockedByTier: Tier? { .gold }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"We can now add this feature to any license that should have access to it:"}],"type":"paragraph"},{"code":["var license1 = License(","    licenseKey: \"1\"",")","","var license2 = License(","    licenseKey: \"2\", ","    features: [AppFeature.dictation]",")","","var license3 = License(","    licenseKey: \"3\",","    tier: .gold",")"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"We can then validate if a license has access to a certain feature:"}],"type":"paragraph"},{"code":["\/\/ Dictation is a license feature, and requires either the feature or the tier","license1.validateFeature(AppFeature.dictation)    \/\/ False","license2.validateFeature(AppFeature.dictation)    \/\/ True","license3.validateFeature(AppFeature.dictation)    \/\/ True","","\/\/ Localization is not a license feature, since it has no ID","license1.validateFeature(AppFeature.localization) \/\/ True","license2.validateFeature(AppFeature.localization) \/\/ True","license3.validateFeature(AppFeature.localization) \/\/ True"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"You can even make it impossible to create instances of a type that requires a certain feature, if the license lacks that feature:"}],"type":"paragraph"},{"code":["class DictationService {","","    init(","        license: License","    ) throws {","        try license.validateFeature(AppFeatures.dictation)","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you try to create a instance with a license that lacks the "},{"type":"codeVoice","code":".dictation"},{"type":"text","text":" feature, the initializer will throw a "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/ValidationError","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Licenses"},"schemaVersion":{"major":0,"