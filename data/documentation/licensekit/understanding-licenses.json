{"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"role":"article","roleHeading":"Article","title":"Understanding Licenses","modules":[{"name":"LicenseKit"}]},"sections":[],"kind":"article","hierarchy":{"paths":[["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit"]]},"abstract":[{"type":"text","text":"This article describes the LicenseKit license model."}],"seeAlsoSections":[{"identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Services"],"title":"Articles","anchor":"Articles","generated":true}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Licenses"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit has a "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","type":"reference","isActive":true},{"type":"text","text":" model that represents a software license that can be resolved with a license key. It can specify an expiration date, license tier, customer information, as well as supported platforms, bundle IDs, environments, features, etc."}]},{"type":"paragraph","inlineContent":[{"text":"LicenseKit can use various services (see ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Services","isActive":true,"type":"reference"},{"text":") to get licenses from the binary, read licenses from files, fetch licenses from remote APIs, integrate with external services like Gumroad, etc.","type":"text"}]},{"inlineContent":[{"type":"text","text":"LicenseKit lets you cache licenses to handle temporary connectivity loss, and use service proxying to combine multiple data sources."}],"type":"paragraph"},{"level":2,"text":"License Engine","type":"heading","anchor":"License-Engine"},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit uses a "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","isActive":true},{"type":"text","text":" to resolve licenses. You can read more about how to create & setup an engine in the main article."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","type":"reference"},{"text":" uses one or multiple ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType"},{"text":"s to fetch licenses, then perform an initial license validation to verify that the license is still valid for the current software and platform, before it returns it to you for further handling.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If a license key or retrieved license is invalid, the license engine will throw a "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/ValidationError","isActive":true,"type":"reference"},{"text":". LicenseKit will use the same logic to validate ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"your"}]},{"text":" license when you create a license engine, as you can use to validate your customer licenses.","type":"text"}],"type":"paragraph"},{"text":"License Capabilities","type":"heading","level":2,"anchor":"License-Capabilities"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","type":"reference","isActive":true},{"type":"text","text":" defines a lot of information, such as "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Customer-swift.struct","isActive":true},{"type":"text","text":" information, which "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment","type":"reference","isActive":true},{"type":"text","text":"s it can be used on, which "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature","isActive":true},{"type":"text","text":"s it unlocks, the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/bundleIds"},{"text":" it’s valid for, and much more.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once you’ve received a customer "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true},{"text":" from the ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","type":"reference","isActive":true},{"text":", you can validate it in many ways. The standard ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validate()"},{"text":" function can be used to verify that it’s valid for the current bundle, platform & date, but there are many other validation functions as well.","type":"text"}]},{"inlineContent":[{"type":"text","text":"For instance "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validateTier(_:)","isActive":true},{"type":"text","text":" let’s you validate that the license meets certain tier criterias, "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validateFeature(_:)"},{"text":" can verify that it unlocks a certain feature, etc.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"License Tiers","anchor":"License-Tiers","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A license tier defines the level of service that a specific "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true,"type":"reference"},{"type":"text","text":" has access to. Common tiers are "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/standard"},{"type":"text","text":", "},{"isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/basic","type":"reference"},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/silver"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/gold","type":"reference","isActive":true},{"text":", and there are also ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/TierGroup","type":"reference","isActive":true},{"type":"text","text":" groups that group related tiers together for certain business models."}]},{"inlineContent":[{"type":"text","text":"You can define custom tiers as well:"}],"type":"paragraph"},{"syntax":"swift","code":["extension License.Tier {","","    static let everything = Self(","        id: \"com.mylibrary.license.everything\",","        name: \"The Everything Tier\",","        level: 1_000","    )","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can then refer to your custom tier when defining licenses in code:"}]},{"syntax":"swift","code":["extension License {","","    static let myCustomerLicense = Self(","        licenseKey: \"DCE54718-A214-40E7-B3E8-3C7B1967F485\",","        customer: .microsoft,","        tier: .everything,","        expirationDate: Date(year: 2025, month: 01, day: 01)","    )","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can make certain types or features require a certain license tier. For instance, this class requires at least a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/silver"},{"type":"text","text":" tier:"}]},{"syntax":"swift","code":["class CoolFeature {","","    init(license: License) throws {","        try license.validateTier(.silver)","        self.locale = locale","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If you try to create an instance of this class with a license that doesn’t have a proper tier, the validation throws a "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/ValidationError","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"type":"heading","text":"License Platforms","level":2,"anchor":"License-Platforms"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Platform","type":"reference","isActive":true},{"text":" enum defines hardware platforms that a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License"},{"type":"text","text":" can be valid for. This means that you can have different license prices for the number of platforms a license supports."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For instance, here we define a license that can only be used on iOS:"}]},{"code":["extension License {","","    static let myBasicCustomersLicense = License(","        licenseKey: \"38B386BD-0684-4A30-B9F5-527FFF15D9BE\",","        tier: .basic,","        platforms: [.iOS]","    )","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you don’t specify a platform for a license, it will support all platforms."}],"type":"paragraph"},{"anchor":"License-Environments","text":"License Environments","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Environment"},{"type":"text","text":" enum defines environments that a "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true},{"text":" can be valid for. This means that you can have different license prices for the number of environments a license supports.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For instance, here we define a license that can only be used in production:"}]},{"type":"codeListing","syntax":"swift","code":["extension License {","","    static let myBasicCustomersLicense = License(","        licenseKey: \"38B386BD-0684-4A30-B9F5-527FFF15D9BE\",","        tier: .basic,","        environments: [.production]","    )","}"]},{"inlineContent":[{"type":"text","text":"If you don’t specify an environment for a license, it will support all platforms."}],"type":"paragraph"},{"type":"heading","level":2,"text":"License Features","anchor":"License-Features"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature"},{"text":" protocol can be implemented by any type that can be unlocked with a license. This means that you can have different license prices for the number of features a license supports.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"To define a license feature, just let a type implement the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature"},{"type":"text","text":" protocol and return an optional "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature\/featureId","isActive":true},{"text":". The feature ID is optional since an enum can define features where only a few cases require a license.","type":"text"}]},{"code":["enum AppFeature: String, LicenseFeature {","    case .dictation","    case .localization","    ","    var featureId: String? { ","        switch self {","        case .dictation: return rawValue","        case .localization: return nil","        }","    }","","    var unlockedByTier: Tier? { .gold }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"We can now add this feature to any license that should have access to it:"}]},{"type":"codeListing","code":["var license1 = License(","    licenseKey: \"1\")","","var license2 = License(","    licenseKey: \"2\", ","    features: [AppFeature.dictation])","","var license3 = License(","    licenseKey: \"3\",","    tier: .gold)"],"syntax":"swift"},{"inlineContent":[{"text":"We can then validate if a license has access to a certain feature:","type":"text"}],"type":"paragraph"},{"code":["license1.validateFeature(AppFeature.dictation)    \/\/ False","license1.validateFeature(AppFeature.localization) \/\/ True","license2.validateFeature(AppFeature.dictation)    \/\/ True","license2.validateFeature(AppFeature.localization) \/\/ True","license3.validateFeature(AppFeature.dictation)    \/\/ True","license3.validateFeature(AppFeature.localization) \/\/ True"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"You can even make it impossible to create instances of a type that requires a certain feature, if the license lacks that feature:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class DictationService {","","    init(license: License) throws {","        try license.validateFeature(AppFeatures.dictation)","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"If you try to create a instance with a license that lacks the ","type":"text"},{"type":"codeVoice","code":".dictation"},{"type":"text","text":" feature, the initializer will throw a "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/ValidationError","type":"reference","isActive":true},{"text":".","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/licensekit\/understanding-licenses"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/licensekit\/understanding-licenses"]}],"references":{"doc://com.licensekit.LicenseKit/documentation/LicenseKit/License/ValidationError":{"fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ValidationError"}],"navigatorTitle":[{"text":"ValidationError","kind":"identifier"}],"abstract":[{"type":"text","text":"This enum defines license validation errors that can"},{"text":" ","type":"text"},{"text":"be thrown when a license key is validated.","type":"text"}],"title":"License.ValidationError","kind":"symbol","role":"symbol","url":"\/documentation\/licensekit\/license\/validationerror","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/ValidationError","type":"topic"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/License/Tier-swift.struct/silver":{"title":"silver","type":"topic","url":"\/documentation\/licensekit\/license\/tier-swift.struct\/silver","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Tier-swift.struct\/silver","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"silver","kind":"identifier"},{"text":": `Self`","kind":"text"}],"role":"symbol","abstract":[{"type":"text","text":"A silver tier with level of "},{"type":"codeVoice","code":"1"},{"type":"text","text":"."}],"kind":"symbol"},"d