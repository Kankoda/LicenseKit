{"variants":[{"paths":["\/documentation\/licensekit\/getting-started-article"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/licensekit\/getting-started-article"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"This article describes how to get started with LicenseKit.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Getting-Started-Article"},"kind":"article","metadata":{"role":"article","modules":[{"name":"LicenseKit"}],"roleHeading":"Article","title":"Getting Started"},"sections":[],"seeAlsoSections":[{"title":"Articles","generated":true,"anchor":"Articles","identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Licenses","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Services"]}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"License Required!","anchor":"License-Required"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This package requires a commercial license to be used. You can sign up for a license from the "},{"type":"reference","isActive":true,"identifier":"https:\/\/kankoda.com\/licensekit"},{"type":"text","text":" or the "},{"type":"reference","isActive":true,"identifier":"https:\/\/kankoda.gumroad.com"},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"License Engine","anchor":"License-Engine"},{"type":"paragraph","inlineContent":[{"text":"With LicenseKit, your app\/library should create a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","type":"reference"},{"text":" with the license key you obtain when signing up for LicenseKit, and define which ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType","type":"reference"},{"text":" you want to use to use to fetch customer licenses.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For instance, this would create a license engine with two licenses that are defined with source code and that will be validated on-device:"}]},{"type":"codeListing","syntax":"swift","code":["let licenseEngine = try await LicenseEngine(","    licenseKey: \"your-license-key\",","    licenseService: { .binary(","        licenses: [","            License(licenseKey: \"license-key-1\", ...),","            License(licenseKey: \"license-key-2\", ...)","        ]","    )}",")"]},{"type":"paragraph","inlineContent":[{"text":"There are many service types to choose from, as described in the ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Services","type":"reference","isActive":true},{"text":" article. You can define licenses with source code, read licenses from file, fetch licenses from an API, integrate with services like Gumroad, etc.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Once you have an engine, you can use ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine\/getLicense(withKey:)","isActive":true},{"text":" to resolve and validate customer licenses by providing a way for your customers to enter ","type":"text"},{"inlineContent":[{"text":"their","type":"text"}],"type":"emphasis"},{"text":" license key. An app can have a UI for this, while a library can have a well-defined setup\/unlock function:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Place this kind of function in your library, where it makes sense. ","\/\/ You don't need a license key when you use encrypted license files.","public static func unlock(","    withLicenseKey key: String",") async throws {","    let license = try await engine.getLicense(for: \"license-key-1\")","    \/\/ Perform further license validations, if needed.","    \/\/ Set up your app\/SDK with the license, if it's valid.","    \/\/ Store the license for the current session, etc.","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The engine will retrieve licenses with the "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType","isActive":true},{"type":"text","text":" that you defined, then validate any matching license for the current platform, product bundle and date. You can perform more validations after getting a license, using its many validation functions."}]},{"type":"heading","level":2,"text":"License Validation","anchor":"License-Validation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","type":"reference","isActive":true},{"type":"text","text":" will automatically validate any fetched license for the current platform, product bundle and date, and will throw a "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/ValidationError","type":"reference","isActive":true},{"type":"text","text":" if the license isn’t valid for the current app\/library."}]},{"type":"paragraph","inlineContent":[{"text":"This means that any license that the engine returns to you ","type":"text"},{"inlineContent":[{"text":"is","type":"text"}],"type":"emphasis"},{"text":" valid for the current app\/library. You can then perform additional validations to ensure that the license meets any additional requirements.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For instance, you can define one or several "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature","isActive":true},{"type":"text","text":" and make sure that the customer license has access to those features:"}]},{"type":"codeListing","syntax":"swift","code":["enum MyLibraryFeature: String, LicenseFeature {","","    case maps, weather, ...","","    var featureId: String? { rawValue }","","    var unlockedByTier: License.Tier? {","        switch self {","        case .maps: return .silver","        case .weather: return .gold","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"You can then validate these features when creating certain types, and throw a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/ValidationError","type":"reference"},{"text":" if the current license doesn’t have the right access to that specific feature:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["public class MyBasicFeature {","","    \/\/ Validate that an optional license is set and is valid","    public init() throws {","        try License.validate(license)","    }","}","","public class MyMapsFeature {","","    \/\/ Validate that an optional license is set and is valid,","    \/\/ and also gives access to the required feature.","    public init() throws {","        try License.validate(license) {","            try $0.validateFeature(MyLibraryFeature.maps)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This means that you can make it impossible to create certain types in your library, while also making some types not require a license."}]},{"type":"heading","level":2,"text":"License Store","anchor":"License-Store"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Most apps and libraries will have a single user at a time, per running instance. For these cases, you can use a "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseStore","isActive":true},{"type":"text","text":" to store the current valid license in a thread-safe way."}]},{"type":"paragraph","inlineContent":[{"text":"For instance, consider that you have a single license store singleton for your app\/library:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["extension LicenseStore {","","    static var myLicenseStore = LicenseStore()","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can then either use "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseStore\/storeLicense(_:)","isActive":true},{"type":"text","text":" to store a license you receive with the "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","isActive":true},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine\/getLicense(withKey:)","isActive":true},{"type":"text","text":", or inject the store into the "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","isActive":true},{"type":"text","text":" to make the engine automatically persist the last fetched, valid license:"}]},{"type":"codeListing","syntax":"swift","code":["let myLicenseEngine = try await LicenseEngine(","    licenseKey: \"your-license-key\",","    licenseStore: .myLicenseStore,","    licenseService: { .binary(","            licenses: [","                License(licenseKey: \"license-key-1\", ...),","                License(licenseKey: \"license-key-2\", ...)","            ]","        )","    }",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After performing a successful "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine\/getLicense(withKey:)"},{"type":"text","text":", the engine will automatically persist the fetched and validated license. You can then use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validate(_:bundleId:date:platform:additionalValidation:)"},{"type":"text","text":" with that license, to both validate that a valid license exists, and to perform additional validations."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To simplify things further, you can create a custom "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License"},{"type":"text","text":" extension to keep track of the current license, for instance something like:"}]},{"type":"codeListing","syntax":"swift","code":["public extension License {","","    static var current: Self? {","        LicenseStore.myLicenseStore.license","    }","} "]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can then use "},{"type":"codeVoice","code":"License.validate(.current, ...)"},{"type":"text","text":" to avoid having to refer to your store instance within in your code base. Your customers can also use this propety to access their license at any time."}]},{"type":"aside","style":"important","name":"Important","content":[{"inlineContent":[{"type":"text","text":"Make sure to keep your license store and engine internal, to avoid that your customers are able to access them, which could make it possible to inject fake licenses into the store."}],"type":"paragraph"}]},{"type":"heading","level":2,"text":"How to setup a license engine","anchor":"How-to-setup-a-license-engine"},{"type":"paragraph","inlineContent":[{"text":"You have to set up your license engine and license validation a bit differently when using LicenseKit in an app vs. in a Swift package.","type":"text"}]},{"type":"heading","level":3,"text":"…for an app","anchor":"for-an-app"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An app can create a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine"},{"type":"text","text":" on launch, or whenever needed. You can provide a UI in the app, where your users can add their license key to unlock more features in the app. This can be an alternative to using in-app purchases or renewable subscriptions."}]},{"type":"heading","level":3,"text":"…for a Swift package","anchor":"for-a-Swift-package"},{"type":"paragraph","inlineContent":[{"text":"A Swift package should provide a way for developers to set up the package with a license key, or by placing an encrypted license file in the main bundle. You can use this to create a license engine in your package, then fetch and validate the license to unlock the package.","type":"text"}]},{"type":"heading","level":2,"text":"Demo apps and inspiration","anchor":"Demo-apps-and-inspiration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Have a look at the demo app and demo library for examples on how to do this. LicenseKit doesn’t put any restrictions on how you use the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseStore"},{"type":"text","text":", but you can use these demos for inspiration."}]},{"type":"heading","level":2,"text":"Further reading","anchor":"Further-reading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See the "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Licenses","type":"reference","isActive":true},{"type":"text","text":" article for more information about the LicenseKit "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","type":"reference","isActive":true},{"type":"text","text":" model, and the "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Services","type":"reference","isActive":true},{"type":"text","text":" article for more information about the available "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType","type":"reference","isActive":true},{"type":"text","text":"s and how they work."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit"]]},"references":{"doc://com.licensekit.LicenseKit/documentation/LicenseKit/License/validate(_:bundleId:date:platform:additionalValidation:)":{"abstract":[{"type":"text","text":"Validate the provided license, if any."}],"title":"validate(_:bundleId:date:platform:additionalValidation:)","role":"symbol","url":"\/documentation\/licensekit\/license\/validate(_:bundleid:date:platform:additionalvalidation:)","type":"topic","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/validate(_:bundleId:date:platform:additionalValidation:)","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"validate"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"License","preciseIdentifier":"s:10LicenseKit0A0V"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"bundleId"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"kind":"externalParam","text":"date"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Date","preciseIdentifier":"s:10Foundation4DateV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"platform"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Platform","preciseIdentifier":"s:10LicenseKit0A0V8PlatformO"},{"kind":"text","text":", "},{"kind":"externalParam","text":"additionalValidation"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","text":"License","preciseIdentifier":"s:10LicenseKit0A0V"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Void","preciseId