This class is the most central type in LicenseKit and is"},{"type":"text","text":" "},{"type":"text","text":"used to fetch licenses using an injected license service."}],"url":"\/documentation\/licensekit\/licenseengine","role":"symbol"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/LicenseStore/storeLicense(_:)":{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseStore\/storeLicense(_:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"storeLicense"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:10LicenseKit0A0V","text":"License"},{"kind":"text","text":")"}],"type":"topic","kind":"symbol","title":"storeLicense(_:)","url":"\/documentation\/licensekit\/licensestore\/storelicense(_:)","abstract":[{"type":"text","text":"Store the provided license."}]},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/License":{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","kind":"symbol","abstract":[{"text":"This struct represents a software license and also works","type":"text"},{"text":" ","type":"text"},{"text":"as a namespace for license-related types.","type":"text"}],"url":"\/documentation\/licensekit\/license","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"License","kind":"identifier"}],"navigatorTitle":[{"text":"License","kind":"identifier"}],"title":"License"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/Understanding-Services":{"url":"\/documentation\/licensekit\/understanding-services","title":"Understanding License Services","role":"article","kind":"article","type":"topic","abstract":[{"text":"This article describes the LicenseKit license service model and how to define and validate licenses.","type":"text"}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Services"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/LicenseFeature":{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseFeature","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LicenseFeature","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/licensekit\/licensefeature","role":"symbol","type":"topic","title":"LicenseFeature","abstract":[{"type":"text","text":"This protocol can be implemented by any type that should"},{"type":"text","text":" "},{"type":"text","text":"be used as a license-based feature."}],"navigatorTitle":[{"text":"LicenseFeature","kind":"identifier"}]},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/LicenseServiceType":{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"LicenseServiceType"}],"type":"topic","abstract":[{"type":"text","text":"This enum defines various license service types that can"},{"type":"text","text":" "},{"type":"text","text":"be used to validate license keys and resolve licenses."}],"url":"\/documentation\/licensekit\/licenseservicetype","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"LicenseServiceType"}],"title":"LicenseServiceType","kind":"symbol"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"op":"replace","value":"occ","path":"\/identifier\/interfaceLanguage"},{"op":"add","value":null,"path":"\/topicSections"},{"op":"replace","value":[{"title":"Articles","anchor":"Articles","generated":true,"identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Licenses","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Services"]}],"path":"\/seeAlsoSections"}]}]}