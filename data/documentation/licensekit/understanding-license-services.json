{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit has many different service types, such as "},{"type":"codeVoice","code":".binary"},{"type":"text","text":", "},{"type":"codeVoice","code":".file"},{"type":"text","text":", "},{"type":"codeVoice","code":".api"},{"type":"text","text":", "},{"type":"codeVoice","code":".gumroad"},{"type":"text","text":", etc."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You specify which service type you want to use when you create a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine"},{"type":"text","text":" instance."}]},{"anchor":"License-Services-Types","level":2,"type":"heading","text":"License Services Types"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType"},{"type":"text","text":" enum defines service types that can be used to resolve licenses for license keys:"}]},{"anchor":"Core-Services","level":3,"type":"heading","text":"Core Services"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":".api"}]},{"type":"text","text":" lets you validate licenses by communicating with an external API."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":".binary"}]},{"type":"text","text":" lets you define licenses with code that is compiled into the binary."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":".file"}]},{"type":"text","text":" lets you provide licenses from a file that is bundled with the binary."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":".fileUrl"}]},{"type":"text","text":" lets you parse licenses from a file at a custom URL."}]}]}]},{"anchor":"Integration-Services","level":3,"type":"heading","text":"Integration Services"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":".gumroad"}]},{"type":"text","text":" lets you validate licenses over the Gumroad validation API."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Reach out if you need support for a 3rd party license provider that is not yet supported."}]},{"anchor":"Service-Wrappers","level":3,"type":"heading","text":"Service Wrappers"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":".proxy"}]},{"type":"text","text":" can be used to combine serveral license services."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":".cached"}]},{"type":"text","text":" can be used to wrap another service and cache any returned licenses."}]}]}]},{"anchor":"Binary-licenses","level":2,"type":"heading","text":"Binary licenses"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Binary licenses are hard-coded into your binary, using plain Swift code. They can always be validated, even when the user is offline, and require you to release new versions of your software to add or remove licenses."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A convenient way to define customers is to create static "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License"},{"type":"text","text":" values:"}]},{"type":"codeListing","syntax":"swift","code":["extension License {","","    \/\/\/ A basic license that only defines a license key","    static let basicLicense = Self(","        licenseKey: \"DCE54718-A214-40E7-B3E8-3C7B1967F485\")","","    \/\/\/ A complete license that defines all definable things","    static let extensiveLicense = Self(","        licenseKey: \"ABCDEFGH-IJKL-MNOP-QRST-UVWXYZ123456\"","        customer: .myCustomer,","        tier: .gold,","        expirationDate: Date(year: 2025, month: 01, day: 01),","        allowsExpiration: false,","        platforms: [.iOS, .tvOS],","        bundleIds: [\"com.customer.library\"]","    )","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also add additional "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License"},{"type":"text","text":" extensions to define all licenses:"}]},{"type":"codeListing","syntax":"swift","code":["extension Collection where Element == License {","","    static var all: [License.Customer] {","        [.basicLicense, .extensiveLicense]","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can then setup your license engine to use a "},{"type":"codeVoice","code":".binary"},{"type":"text","text":" service with these licenses:"}]},{"type":"codeListing","syntax":"swift","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","   try .binary(licenses: .all)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/allowsExpiration"},{"type":"text","text":" to control whether or not a license should still be valid after the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/expirationDate"},{"type":"text","text":" is passed. Companies like Sketch use a model where licenses are always valid in all versions that were released during the license validity period."}]},{"anchor":"File-based-licenses","level":2,"type":"heading","text":"File-based licenses"},{"type":"paragraph","inlineContent":[{"type":"text","text":"File-based licenses are defined in files that are bundled with the library or app binary. They can always be validated, even when the user is offline, and require you to release new versions of your software to add or remove licenses."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For instance, imagine having a “licenses.csv” file with rows that define license key, company name, license tier and expiration date:"}]},{"type":"codeListing","syntax":null,"code":["DCE54718-A214-40E7-B3E8-3C7B1967F485,Microsoft,BASIC,2023-10-01","ABCDEFGH-IJKL-MNOP-QRST-UVWXYZ123456,Apple,GOLD,2023-01-01","13AGU32F-4ER5-O97Y-76YR-IYT785TU56F7,Meta,SILVER,2024-07-13"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can now setup your license engine to use a "},{"type":"codeVoice","code":".file"},{"type":"text","text":" service with this file:"}]},{"type":"codeListing","syntax":"swift","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","    try .file(","        fileName: \"licenses\",","        fileExtension: \"csv\"","    ) { rows in","        rows.map {","            License(","                licenseKey: row[0],","                customer: .init(name: row[1])","                tier: .init(name: row[2])","            )","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the code above, we register a service that parses a file with the filename “licenses.csv” in the main bundle, then maps every row to a license by using the first value as license key and the second as company name."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/allowsExpiration"},{"type":"text","text":" to control whether or not a license should still be valid after the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/expirationDate"},{"type":"text","text":" is passed. Companies like Sketch use a model where licenses are always valid in all versions that were released during the license validity period."}]},{"anchor":"Gumroad-licenses","level":2,"type":"heading","text":"Gumroad licenses"},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit lets you seamlessly integrate with the Gumroad license validation API."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use a "},{"type":"codeVoice","code":".gumroad"},{"type":"text","text":" service to fetch Gumroad licenses, and provide a license mapping function that will be used to map the Gumroad response to a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","    try .gumroad(","        productId: \"unique-product-id\",","        licenseMapping { response in","            var license = response.license","            \/\/ You can customize or replace this standard license","            return license","        }","    )","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can either just return the response’s standard license, customize or replace it, or map the raw responses in any way you want."}]},{"anchor":"APICloud-based-licenses","level":2,"type":"heading","text":"API\/Cloud-based licenses"},{"type":"paragraph","inlineContent":[{"type":"text","text":"API\/Cloud-based licenses use a remote API or web service to validate licenses with async network calls."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Connecting over the Internet means that the device must be online to fetch licenses. You can however use a cached license wrapper to cache successful license validations."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To map licenses from a remote api, you must define a "},{"type":"codeVoice","code":"Decodable"},{"type":"text","text":" type that can decode the API response, for instance:"}]},{"type":"codeListing","syntax":"swift","code":["struct ApiLicenseModel: Decodable {","","   let licenseKey: String","","   var license: License {","       License(licenseKey: licenseKey)","   }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This custom type would be able to map the following API response:"}]},{"type":"codeListing","syntax":"swift","code":["{","    \"licenseKey\": \"ABC123\",","    \"customerName\": \"Cool Company Ltd.\",","    \"expirationDate\": \"2027-01-31\"","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can then use an "},{"type":"codeVoice","code":".api"},{"type":"text","text":" service to fetch data, then use the mapping function to decode the data and map it to a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","    try .api(","        configuration: .init(","            url: { licenseKey in","                URL(string: \"https:\/\/myapi.com\/v1\/licenses\/validate\/\\(licenseKey)\")!","            },","            httpMethod: { licenseKey in \"POST\" },","            httpHeaders: { licenseKey in ","                [","                    \"api-token\": \"ejiwaogja=\",","                    \"some-other-info\": \"let's go!\"","                ] ","            }","        ),","        licenseMapping { data in","            let decoder = JSONDecoder()","            let response = try decoder.decode(ApiLicenseModel.self, from: data)","            License(licenseKey: response.licenseKey)","        }","    )","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This way to provide a configuration and a mapping function lets you customize this service to great extent."}]},{"anchor":"Cached-licenses","level":2,"type":"heading","text":"Cached licenses"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use a "},{"type":"codeVoice","code":".cached"},{"type":"text","text":" service to wrap another license service and make it cache successful license validations. It will then return the last successfully fetched license for a certain key, if the licese validation fails due to a network error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This makes it possible for a user to keep using your software even when the device is disconnected."}]},{"type":"codeListing","syntax":"swift","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","    try .cached(","        service: .api<ApiLicense>(...)","    )","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any license validations that fail due to a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseError"},{"type":"text","text":" will cause the cache to reset and the validation to fail with the original error."}]},{"anchor":"Service-Proxying","level":2,"type":"heading","text":"Service Proxying"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use a "},{"type":"codeVoice","code":".proxy"},{"type":"text","text":" service to combine several services into a single one. This makes is possible to e.g. perform both code-, file- and api-based license validation with a single service."}]},{"type":"codeListing","syntax":"swift","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","    try .proxy(","        services: [","            .binary(","                license: license,","                customerLicenses: .all","            ),","            try .gumroad(","                license: license,","                productId: \"unique-product-id\",","                licenseMapping { response in","                    ...","                }","            )","        ]","    )","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can apply different "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Source-swift.enum"},{"type":"text","text":"s to the different licenses, and handle licenses differently based on from where they came."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["\/documentation\/licensekit\/understanding-license-services"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/licensekit\/understanding-license-services"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"url":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Services","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"This article describes the LicenseKit license service model and how to define and validate licenses."}],"kind":"article","metadata":{"roleHeading":"Article","title":"Understanding License Services","role":"article","modules":[{"name":"LicenseKit"}]},"hierarchy":{"paths":[["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit"]]},"seeAlsoSections":[{"title":"Articles","identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Getting-Started","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Licenses","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Errors"],"generated":true}],"references":{"doc://com.licensekit.LicenseKit/documentation/LicenseKit/License/allowsExpiration":{"role":"symbol","title":"allowsExpiration","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"allowsExpiration"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"abstract":[{"type":"text","text":"Whether or not expiration is allowed in all builds."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/allowsExpiration","kind":"symbol","type":"topic","url":"\/documentation\/licensekit\/license\/allowsexpiration"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/LicenseEngine":{"role":"symbol","title":"LicenseEngine","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"LicenseEngine"}],"abstract":[{"type":"text","text":"This is the most central class in LicenseKit and is used to"},{"type":"text","text":" "},{"type":"text","text":"resolve license keys."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"LicenseEngine"}],"url":"\/documentation\/licensekit\/licenseengine"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit":{"role":"collection","title":"LicenseKit","abstract":[{"type":"text","text":"LicenseKit helps you protect your Swift-based software with commercial licenses."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit","kind":"symbol","type":"topic","url":"\/documentation\/licensekit"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/License":{"role":"symbol","title":"License","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"License"}],"abstract":[{"type":"text","text":"This struct represents a software license and also works as"},{"type":"text","text":" "},{"type":"text","text":"a namespace for license-related types."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"License"}],"url":"\/documentation\/licensekit\/license"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/LicenseError":{"role":"symbol","title":"LicenseError","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"LicenseError"}],"abstract":[{"type":"text","text":"This enum defines various license errors that can be thrown"},{"type":"text","text":" "},{"type":"text","text":"when registering a license key or trying to access features"},{"type":"text","text":" "},{"type":"text","text":"that require a specific license type."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseError","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"LicenseError"}],"url":"\/documentation\/licensekit\/licenseerror"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/License/Source-swift.enum":{"role":"symbol","title":"License.Source","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Source"}],"abstract":[{"type":"text","text":"This enum specifies various license sources, from which"},{"type":"text","text":" "},{"type":"text","text":"licenses can be read or fetched."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Source-swift.enum","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Source"}],"url":"\/documentation\/licensekit\/license\/source-swift.enum"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/Understanding-License-Errors":{"role":"article","title":"Understanding License Errors","abstract":[{"type":"text","text":"This article describes the license error model and how to handle errors that are thrown."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Errors","kind":"article","type":"topic","url":"\/documentation\/licensekit\/understanding-license-errors"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/Getting-Started":{"role":"article","title":"Getting started","abstract":[{"type":"text","text":"This article describes how to get started with LicenseKit."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Getting-Started","kind":"article","type":"topic","url":"\/documentation\/licensekit\/getting-started"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/License/expirationDate":{"role":"symbol","title":"expirationDate","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"expirationDate"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Date","preciseIdentifier":"s:10Foundation4DateV"},{"kind":"text","text":"?"}],"abstract":[{"type":"text","text":"The license expiration date, if any."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/expirationDate","kind":"symbol","type":"topic","url":"\/documentation\/licensekit\/license\/expirationdate"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/LicenseServiceType":{"role":"symbol","title":"LicenseServiceType","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"LicenseServiceType"}],"abstract":[{"type":"text","text":"This enum defines various license service types that can be"},{"type":"text","text":" "},{"type":"text","text":"used to get customer licenses."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"LicenseServiceType"}],"url":"\/documentation\/licensekit\/licenseservicetype"},"doc://com.licensekit.LicenseKit/documentation/LicenseKit/Understanding-Licenses":{"role":"article","title":"Understanding Licenses","abstract":[{"type":"text","text":"This article describes the LicenseKit license model."}],"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Licenses","kind":"article","type":"topic","url":"\/documentation\/licensekit\/understanding-licenses"}},"variantOverrides":[{"patch":[{"op":"replace","path":"\/identifier\/interfaceLanguage","value":"occ"},{"op":"add","path":"\/topicSections","value":null},{"op":"replace","path":"\/seeAlsoSections","value":[{"title":"Articles","identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Getting-Started","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Licenses","doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Errors"],"generated":true}]}],"traits":[{"interfaceLanguage":"occ"}]}]}