{"seeAlsoSections":[{"title":"Articles","anchor":"Articles","generated":true,"identifiers":["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-Licenses"]}],"identifier":{"url":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/Understanding-License-Services","interfaceLanguage":"swift"},"sections":[],"abstract":[{"text":"This article describes the LicenseKit license service model and how to define and validate licenses.","type":"text"}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"LicenseKit has many different service types, such as ","type":"text"},{"code":".binary","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":".file"},{"type":"text","text":", "},{"code":".api","type":"codeVoice"},{"text":", ","type":"text"},{"code":".gumroad","type":"codeVoice"},{"text":", etc.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You specify which service type you want to use when you create a ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseEngine","type":"reference","isActive":true},{"type":"text","text":" instance."}]},{"level":2,"text":"License Services Types","anchor":"License-Services-Types","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType"},{"type":"text","text":" enum defines service types that can be used to resolve customer licenses:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType\/api(configuration:cached:urlSession:licenseMapping:)","isActive":true,"type":"reference"},{"type":"text","text":" fetches licenses from an external API."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType\/binary(licenses:)","isActive":true,"type":"reference"},{"type":"text","text":" lets you define licenses with code."}]}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType\/cached(service:)"},{"text":" can cache another service.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType\/file(fileName:fileExtension:bundle:componentSeparator:licenseMapping:)"},{"text":" can read licenses from file.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType\/gumroad(productId:cached:urlSession:licenseMapping:)","isActive":true},{"text":" can integrate with the Gumroad API.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/LicenseServiceType\/proxy(services:)"},{"type":"text","text":" can combine several services into one."}]}]}]},{"level":2,"anchor":"Binary-licenses","type":"heading","text":"Binary licenses"},{"type":"paragraph","inlineContent":[{"text":"Binary licenses are hard-coded into your binary, using plain Swift code. They can always be validated, even when the user is offline, and require you to release new versions of your software to add or remove licenses.","type":"text"}]},{"inlineContent":[{"type":"text","text":"A convenient way to define customers is to create static "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true},{"type":"text","text":" values:"}],"type":"paragraph"},{"syntax":"swift","code":["extension License {","","    \/\/\/ A basic license that only defines a license key","    static let basicLicense = Self(","        licenseKey: \"DCE54718-A214-40E7-B3E8-3C7B1967F485\")","","    \/\/\/ A complete license that defines all definable things","    static let extensiveLicense = Self(","        licenseKey: \"ABCDEFGH-IJKL-MNOP-QRST-UVWXYZ123456\"","        customer: .myCustomer,","        tier: .gold,","        expirationDate: Date(year: 2025, month: 01, day: 01),","        allowsExpiration: false,","        platforms: [.iOS, .tvOS],","        bundleIds: [\"com.customer.library\"]","    )","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also add additional "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License","isActive":true,"type":"reference"},{"type":"text","text":" extensions to define all licenses:"}]},{"code":["extension Collection where Element == License {","","    static var all: [License.Customer] {","        [.basicLicense, .extensiveLicense]","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"You can then setup your license engine to use a "},{"type":"codeVoice","code":".binary"},{"type":"text","text":" service with these licenses:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","   try .binary(licenses: .all)","}"]},{"type":"paragraph","inlineContent":[{"text":"You can use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/allowsExpiration"},{"type":"text","text":" to control whether or not a license should still be valid after the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/expirationDate"},{"text":" is passed. Companies like Sketch use a model where licenses are always valid in all versions that were released during the license validity period.","type":"text"}]},{"anchor":"File-based-licenses","text":"File-based licenses","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"File-based licenses are defined in files that are bundled with the library or app binary. They can always be validated, even when the user is offline, and require you to release new versions of your software to add or remove licenses."}]},{"type":"paragraph","inlineContent":[{"text":"For instance, imagine having a “licenses.csv” file with rows that define license key, company name, license tier and expiration date:","type":"text"}]},{"type":"codeListing","code":["DCE54718-A214-40E7-B3E8-3C7B1967F485,Microsoft,BASIC,2023-10-01","ABCDEFGH-IJKL-MNOP-QRST-UVWXYZ123456,Apple,GOLD,2023-01-01","13AGU32F-4ER5-O97Y-76YR-IYT785TU56F7,Meta,SILVER,2024-07-13"],"syntax":null},{"inlineContent":[{"text":"You can now setup your license engine to use a ","type":"text"},{"code":".file","type":"codeVoice"},{"type":"text","text":" service with this file:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","    try .file(","        fileName: \"licenses\",","        fileExtension: \"csv\"","    ) { rows in","        rows.map {","            License(","                licenseKey: row[0],","                customer: .init(name: row[1])","                tier: .init(name: row[2])","            )","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the code above, we register a service that parses a file with the filename “licenses.csv” in the main bundle, then maps every row to a license by using the first value as license key and the second as company name."}]},{"inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/allowsExpiration","isActive":true},{"text":" to control whether or not a license should still be valid after the ","type":"text"},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/expirationDate","isActive":true,"type":"reference"},{"text":" is passed. Companies like Sketch use a model where licenses are always valid in all versions that were released during the license validity period.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Gumroad-licenses","text":"Gumroad licenses","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"LicenseKit lets you seamlessly integrate with the Gumroad license validation API."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use a "},{"type":"codeVoice","code":".gumroad"},{"text":" service to fetch Gumroad licenses, and provide a license mapping function that will be used to map the Gumroad response to a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","    try .gumroad(","        productId: \"unique-product-id\",","        licenseMapping { response in","            var license = response.license","            \/\/ You can customize or replace this standard license","            return license","        }","    )","}"]},{"inlineContent":[{"type":"text","text":"You can either just return the response’s standard license, customize or replace it, or map the raw responses in any way you want."}],"type":"paragraph"},{"level":2,"anchor":"API-based-licenses","type":"heading","text":"API-based licenses"},{"inlineContent":[{"type":"text","text":"API-based licenses use a remote API or web service to validate licenses with async network calls."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Connecting over the Internet means that the device must be online to fetch licenses. You can however use a cached license wrapper to cache successful license validations."}],"type":"paragraph"},{"inlineContent":[{"text":"To map licenses from a remote api, you must define a ","type":"text"},{"code":"Decodable","type":"codeVoice"},{"text":" type that can decode the API response, for instance:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["struct ApiLicenseModel: Decodable {","","   let licenseKey: String","","   var license: License {","       License(licenseKey: licenseKey)","   }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"This custom type would be able to map the following API response:"}],"type":"paragraph"},{"type":"codeListing","code":["{","    \"licenseKey\": \"ABC123\",","    \"customerName\": \"Cool Company Ltd.\",","    \"expirationDate\": \"2027-01-31\"","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can then use an "},{"type":"codeVoice","code":".api"},{"type":"text","text":" service to fetch data, then use the mapping function to decode the data and map it to a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","    try .api(","        configuration: .init(","            url: { licenseKey in","                URL(string: \"https:\/\/myapi.com\/v1\/licenses\/validate\/\\(licenseKey)\")!","            },","            httpMethod: { licenseKey in \"POST\" },","            httpHeaders: { licenseKey in ","                [","                    \"api-token\": \"ejiwaogja=\",","                    \"some-other-info\": \"let's go!\"","                ] ","            }","        ),","        licenseMapping { data in","            let decoder = JSONDecoder()","            let response = try decoder.decode(ApiLicenseModel.self, from: data)","            License(licenseKey: response.licenseKey)","        }","    )","}"]},{"inlineContent":[{"type":"text","text":"This way to provide a configuration and a mapping function lets you customize this service to great extent."}],"type":"paragraph"},{"anchor":"Cached-licenses","text":"Cached licenses","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"You can use a ","type":"text"},{"type":"codeVoice","code":".cached"},{"text":" service to wrap another license service and make it cache successful license validations. It will then return the last successfully fetched license for a certain key, if the licese validation fails due to a network error.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This makes it possible for a user to keep using your software even when the device is disconnected."}],"type":"paragraph"},{"type":"codeListing","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","    try .cached(","        service: .api<ApiLicense>(...)","    )","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any license validations that fail due to a "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/ValidationError","isActive":true,"type":"reference"},{"type":"text","text":" causes the cache to reset and the validation to fail with the original error."}]},{"type":"heading","level":2,"anchor":"Service-Proxying","text":"Service Proxying"},{"type":"paragraph","inlineContent":[{"text":"You can use a ","type":"text"},{"type":"codeVoice","code":".proxy"},{"type":"text","text":" service to combine several services into a single one. This makes is possible to e.g. perform both code-, file- and api-based license validation with a single service."}]},{"syntax":"swift","code":["let engine = try await LicenseEngine(licenseKey: \"your-key\") {","    try .proxy(","        services: [","            .binary(","                license: license,","                customerLicenses: .all","            ),","            try .gumroad(","                license: license,","                productId: \"unique-product-id\",","                licenseMapping { response in","                    ...","                }","            )","        ]","    )","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can apply different "},{"identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Source-swift.enum","isActive":true,"type":"reference"},{"type":"text","text":"s to the different licenses, and handle licenses differently based on from where they came."}]}],"kind":"content"}],"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/licensekit\/understanding-license-services"]},{"paths":["\/documentation\/licensekit\/understanding-license-services"],"traits":[{"interfaceLanguage":"occ"}]}],"metadata":{"roleHeading":"Article","role":"article","title":"Understanding License Services","modules":[{"name":"LicenseKit"}]},"hierarchy":{"paths":[["doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://com.licensekit.LicenseKit/documentation/LicenseKit/License/Source-swift.enum":{"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Source"}],"abstract":[{"text":"This enum defines various license sources from which","type":"text"},{"type":"text","text":" "},{"type":"text","text":"licenses can be read or fetched."}],"type":"topic","title":"License.Source","navigatorTitle":[{"kind":"identifier","text":"Source"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/com.licensekit.LicenseKit\/documentation\/LicenseKit\/License\/Source-swift.enum","url":"\/documentation\/licensekit\/license\/source-s